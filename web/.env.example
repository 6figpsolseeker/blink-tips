# Solana RPC endpoint. Defaults to public devnet if unset.
# For production, use a dedicated provider (Helius, Triton, QuickNode).
RPC_URL=https://api.devnet.solana.com

# Deployed tip-vault program ID. Regenerate via `anchor keys sync` after first build.
TIP_VAULT_PROGRAM_ID=TipV1111111111111111111111111111111111111
