# ─── Network ────────────────────────────────────────────────────────────────
# "devnet" (default) or "mainnet". Controls the USDC mint default and whether
# RPC_URL is required.
NETWORK=devnet

# ─── RPC ────────────────────────────────────────────────────────────────────
# Solana RPC endpoint.
#   NETWORK=devnet : falls back to https://api.devnet.solana.com if unset.
#   NETWORK=mainnet: REQUIRED. Public mainnet throttles hard — use a dedicated
#                    provider (Helius, Triton, QuickNode). Endpoints return
#                    503 with a clear message when unset on mainnet.
RPC_URL=https://api.devnet.solana.com

# ─── Program ID ─────────────────────────────────────────────────────────────
# Deployed tip-vault program ID. For mainnet deploy, generate a fresh keypair
# and replace this with the resulting program ID.
TIP_VAULT_PROGRAM_ID=F9GaSaT6KG1pwjRcnZvfmNMyEoxLHqe5MMVQFgvg6Kiw

# ─── USDC ───────────────────────────────────────────────────────────────────
# Optional explicit USDC mint override. Leave unset to pick based on NETWORK:
#   devnet : 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
#   mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# USDC_MINT=
